{
    // ─── Font & leggibilità ───────────────────────────────────────────
    "editor.fontFamily": "'JetBrains Mono', 'Fira Code', monospace",
    "editor.fontSize": 14,
    "editor.lineHeight": 1.6,
    "editor.fontLigatures": true,
    "editor.fontWeight": "400",
    "editor.letterSpacing": 0.3,
    "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
    "terminal.integrated.fontSize": 13,
    // ─── Tema & colori (stile IntelliJ) ──────────────────────────────
    // Installa l'estensione "One Dark Pro" o "IntelliJ IDEA Theme"
    "workbench.colorTheme": "Light 2026",
    // Installa l'estensione "Material Icon Theme"
    "workbench.iconTheme": "material-icon-theme",
    "editor.semanticHighlighting.enabled": true,
    // ─── Layout stile IntelliJ ────────────────────────────────────────
    "editor.minimap.enabled": false,
    "workbench.sideBar.location": "left",
    "workbench.tree.indent": 16,
    "workbench.tree.renderIndentGuides": "always",
    "explorer.compactFolders": false,
    "breadcrumbs.enabled": true,
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.tabSizing": "fit",
    "workbench.startupEditor": "none",
    "workbench.panel.defaultLocation": "bottom",
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.revealIfOpen": true,
    "workbench.editor.wrapTabs": false,
    "workbench.editor.tabActionCloseVisibility": true,
    // ─── Animazioni & scorrimento fluido ─────────────────────────────
    "editor.smoothScrolling": true,
    "terminal.integrated.smoothScrolling": true,
    "workbench.list.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorBlinking": "phase",
    // ─── Editor & produttività ────────────────────────────────────────
    "editor.formatOnSave": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,
    "editor.renderWhitespace": "boundary",
    "editor.wordWrap": "off",
    "editor.rulers": [
        120
    ],
    "editor.stickyScroll.enabled": true,
    "editor.inlayHints.enabled": "on",
    "editor.acceptSuggestionOnEnter": "smart",
    "files.autoSave": "onFocusChange",
    // ─── Comportamento editor stile IntelliJ ─────────────────────────
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    "editor.showFoldingControls": "always",
    "editor.foldingStrategy": "indentation",
    "editor.linkedEditing": true,
    "editor.suggest.insertMode": "replace",
    "editor.suggest.showStatusBar": true,
    "editor.parameterHints.enabled": true,
    "editor.quickSuggestionsDelay": 0,
    "editor.hover.delay": 300,
    "editor.multiCursorModifier": "alt",
    "editor.find.autoFindInSelection": "multiline",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "editor.gotoLocation.multipleImplementations": "peek",
    "editor.gotoLocation.multipleReferences": "peek",
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    // ─── File handling stile IntelliJ ────────────────────────────────
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/node_modules": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/target": true
    },
    // ─── Ricerca stile IntelliJ ──────────────────────────────────────
    "search.smartCase": true,
    "search.useIgnoreFiles": true,
    "search.exclude": {
        "**/node_modules": true,
        "**/target": true,
        "**/.git": true
    },
    // ─── Problemi & diagnostica ──────────────────────────────────────
    "problems.showCurrentInStatus": true,
    "editor.showUnused": true,
    "editor.lightbulb.enabled": "on",
    // ─── Git stile IntelliJ ──────────────────────────────────────────
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": true,
    "git.decorations.enabled": true,
    "scm.diffDecorations": "all",
    "scm.diffDecorationsGutterVisibility": "always",
    // ─── Terminale integrato ─────────────────────────────────────────
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.scrollback": 10000,
    "kafka.clusters.selected": "Local-bG9jYWxob3N0OjkwOTI",
    // ─── Task Buttons (status bar) ────────────────────────────────────
    "VsCodeTaskButtons.tasks": [
        {
            "label": "$(play) Run",
            "task": "Camel: Run (file corrente)",
            "tooltip": "camel run sul file aperto"
        },
        {
            "label": "$(sync~spin) Dev",
            "task": "Camel: Run --dev (hot reload)",
            "tooltip": "camel run --dev (hot reload)"
        },
        {
            "label": "$(check) Dry-run",
            "task": "Camel: Dry-run (valida senza eseguire)",
            "tooltip": "Valida il file senza eseguirlo"
        },
        {
            "label": "$(database) Kafka up",
            "task": "Docker: kafka up",
            "tooltip": "Avvia Kafka con docker-compose"
        },
        {
            "label": "$(stop-circle) Kafka down",
            "task": "Docker: kafka down",
            "tooltip": "Ferma Kafka"
        }
    ],
    // ─── Estensioni consigliate per esperienza IntelliJ completa ─────
    // - "k--kato.intellij-idea-keybindings"  → scorciatoie IntelliJ
    // - "streetsidesoftware.code-spell-checker"
    // - "eamodio.gitlens"                    → git avanzato
    // - "usernamehw.errorlens"               → errori inline (stile IDEA)
    // - "pflannery.vscode-versionlens"       → versioni dipendenze
    // - "gruntfuggly.todo-tree"              → TODO/FIXME panel
}
